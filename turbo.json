{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "apps/web/.env",
    "packages/database/supabase/config.toml",
    "packages/database/supabase/seed.sql"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": [
        "dist/**"
      ]
    },
    "typecheck": {},
    "preview": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "db:start": {
      "cache": false
    },
    "db:stop": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    },
    "test": {},
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
