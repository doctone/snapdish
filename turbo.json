{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".env",
    "packages/database/supabase/config.toml",
    "packages/database/supabase/seed.sql"
  ],
  "tasks": {
    "//#dev": {
      "cache": false,
      "persistent": true
    },
    "//#build": {
      "outputs": [
        "dist/**"
      ]
    },
    "//#typecheck": {},
    "db:start": {
      "cache": false
    },
    "db:stop": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    }
  }
}
